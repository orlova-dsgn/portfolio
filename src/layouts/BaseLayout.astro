---
import Header from '@/components/Header.astro';
import ContactMe from '@/components/ContactMe.astro';
import { MobileMenu } from '@/components/MobileMenu';
---

<html lang="ru" class="scrollbar-gutter-stable">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Елизавета Орлова | UI/UX Designer</title>
  </head>

  <body
    class={"flex h-screen overflow-hidden text-black max-mobile:overflow-auto max-mobile:block max-mobile:h-auto bg-[url('/pattern.svg')] bg-position-[16px_15px] bg-repeat bg-brand-gray-bg"}
  >
    <div class="max-mobile:block hidden">
      <MobileMenu client:media="(max-width: 960px)">
        <ContactMe />
      </MobileMenu>
    </div>

    <Header />

    <main class="max-mobile:px-4 flex-1 overflow-y-auto px-9 pt-9 pb-32">
      <div class="mx-auto max-w-300">
        <slot />
      </div>
    </main>
  </body>
</html>
