---
import Header from '@/components/Header.astro';
import { MobileMenu } from '@/components/MobileMenu';
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Елизавета Орлова | UI/UX Designer</title>
  </head>

  <body class="flex h-screen overflow-hidden bg-white text-black">
    <Header headerClassName="max-mobile:hidden" />

    <main
      class="bg-brand-gray-bg max-mobile:p-4 flex-1 overflow-y-auto bg-[url('/pattern.svg')] bg-position-[16px_15px] bg-repeat p-9 pb-32"
    >
      <div class="mx-auto max-w-300">
        <div class="max-mobile:block hidden">
          <MobileMenu client:media="(max-width: 960px)" />
        </div>
        <slot />
      </div>
    </main>
  </body>
</html>
