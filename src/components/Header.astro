---
import { Image } from 'astro:assets';

import { cn } from '@/lib/utils';
import elizabethPhoto from '@/assets/elizabeth.png';

import ContactMe from './ContactMe.astro';
import NavigationLinks from './NavigationLinks.astro';

const isAboutPage = Astro.url.pathname.includes('/about');
const isCasePage = Astro.url.pathname.includes('/case-');
---

<header
  class={cn(
    'border-brand-border2 flex h-full max-w-100 flex-col justify-between overflow-hidden border-r p-9  max-mobile:px-4 max-mobile:pb-22 bg-white max-mobile:max-w-none max-mobile:border-r-0 max-mobile:border-b max-mobile:overflow-auto max-mobile:min-h-screen',
    isAboutPage && 'max-mobile:hidden',
    isCasePage && 'hidden'
  )}
>
  <nav class="max-mobile:hidden flex gap-3">
    <NavigationLinks />
  </nav>

  <div class="max-mobile:-mt-5">
    <Image
      src={elizabethPhoto}
      alt="Елизавета Орлова"
      class="h-30 w-30 object-contain"
    />
    <div class="mt-5 flex flex-col gap-3">
      <div class="flex gap-2">
        <h4>Елизавета Орлова</h4>
        <h4 class="text-brand-gray2">[Москва]</h4>
      </div>
      <h1 class="text-brand-blue">UX/UI-дизайнер</h1>
      <div class="max-w-82">
        <p class="text-default mb-3">
          Имею опыт более двух лет в дизайне интерфейсов. Улучшила
          пользовательский опыт личного кабинета для пациентов
          НИИР им. В.А. Насоновой.
        </p>
        <p class="text-default mb-3">
          До этого больше года создавала для них диджитал дизайн, провела
          редизайн сайта с нуля.
        </p>
        <p class="text-default mb-3">
          Мои решения помогли снизить количество обращений в техническую
          поддержку.
        </p>
      </div>
      <div>
        <a
          class="btn-brand bg-brand-blue text-white"
          href="/Resume_OrlovaES_UXUI-designer.pdf"
          target="_blank"
          rel="noopener noreferrer">резюме (pdf)</a
        >
      </div>
    </div>
  </div>

  <div>
    <div class="max-mobile:hidden flex flex-col gap-2">
      <ContactMe />
    </div>
  </div>
</header>
