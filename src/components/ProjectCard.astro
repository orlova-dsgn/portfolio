---
import { Image } from 'astro:assets';

import type { Project } from '@/types';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const { id, title, subtitle, description, image1, cardWidth, imgWidth } =
  project;
---

<a href={id} id={id} style=`width: ${cardWidth}`>
  <div
    class="border-brand-border2 hover:border-brand-blue cursor-pointer border bg-white p-4 transition-colors"
  >
    <div class="bg-brand-gray2-bg flex aspect-video items-end justify-center">
      <Image
        src={image1}
        alt="Кейс"
        class="object-contain"
        style=`width: ${imgWidth}`
      />
    </div>

    <div class="mt-6 flex flex-col gap-2">
      <div class="max-mobile:flex-col-reverse flex gap-3">
        <h3>{title}</h3>
        <h3 class="max-mobile:gap-1 text-brand-gray2 flex gap-3">
          <span>•</span>
          <span>{subtitle}</span>
        </h3>
      </div>
      <p class="text-default pb-3">{description}</p>
    </div>
  </div>
</a>
